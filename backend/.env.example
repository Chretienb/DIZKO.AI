PORT=4000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── Replicate (AI stem separation via Demucs) ─────────────────────────────────
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-token

# ── Instrument tagger (content-based instrument ID) — optional ────────────────
# The Python PANNs worker in /instrument-service (deploy to Railway). Identifies
# a stem's instrument from the audio when the user didn't pick one. Leave blank
# to disable (falls back to filename/user-pick heuristic — no behavior change).
INSTRUMENT_SERVICE_URL=
INSTRUMENT_AUTH_TOKEN=    # shared secret — set the SAME value on the worker

# ── Anthropic (AI track naming via Claude Haiku) ──────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
# Leave blank to use smart heuristic naming instead
ANTHROPIC_API_KEY=

# ── Error monitoring (Sentry) — optional ──────────────────────────────────────
# Create a project at https://sentry.io and paste its DSN.
# Leave blank to disable (the app runs fine without it).
SENTRY_DSN=

# ── Redis — optional (horizontal scaling) ────────────────────────────────────
# Shares single-process state (rate-limit windows, JWT cache, notification
# dedup) across instances. Leave blank to run fully in-memory (correct for a
# single instance). Set to your Redis/Valkey URL when running more than one.
REDIS_URL=

# ── R2 storage cleanup — optional ─────────────────────────────────────────────
# The daily job sweeps R2 for orphaned stem/take objects and stale export zips.
# It runs in DRY-RUN by default (logs candidates, deletes nothing). Set to
# "true" only after reviewing a few dry-run logs to actually delete.
R2_CLEANUP_ENABLED=
