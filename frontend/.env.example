# Frontend environment — all VITE_* vars are PUBLIC (bundled into the client).
# Copy to .env and fill in. Do not put secrets here.

# ── Supabase (public anon key only) ───────────────────────────────────────────
# Find these in your project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Error monitoring (Sentry) — optional ──────────────────────────────────────
# Create a project at https://sentry.io and paste its DSN.
# Leave blank to disable (the app runs fine without it).
VITE_SENTRY_DSN=
# Optional — performance trace sample rate (0..1, default 1.0) and release tag.
VITE_SENTRY_TRACES_RATE=
VITE_SENTRY_RELEASE=
# Build-time ONLY (not bundled): org auth token for source-map upload, so prod
# stack traces map to real source. Create at Settings → Auth Tokens in Sentry.
# Leave blank to skip upload (build still works; prod traces stay minified).
SENTRY_AUTH_TOKEN=
